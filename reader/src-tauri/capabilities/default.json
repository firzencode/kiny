{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "reader 默认权限：读库目录、文件对话框",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "log:default",
    "opener:default",
    "clipboard-manager:allow-write-text",
    { "identifier": "opener:allow-open-path", "allow": [{ "path": "$HOME/**" }] },
    { "identifier": "fs:allow-read-text-file", "allow": [{ "path": "$APPDATA/**" }, { "path": "$APPLOG/**" }] },
    { "identifier": "fs:allow-read-dir", "allow": [{ "path": "$APPDATA/**" }] },
    { "identifier": "fs:allow-exists", "allow": [{ "path": "$APPDATA/**" }] }
  ]
}

{
  "name": "@kiny/web-reader",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ../scripts/stage-sample.mjs ../samples/雾港之夜 public/demo --files-json",
    "dev": "vite",
    "prebuild": "node ../scripts/stage-sample.mjs ../samples/雾港之夜 public/demo --files-json",
    "build": "tsc --noEmit && vite build",
    "build:template": "vite build --mode template",
    "preview": "vite preview",
    "pretest": "node ../scripts/stage-sample.mjs ../samples/雾港之夜 public/demo --files-json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kiny/engine": "file:../engine",
    "@kiny/player": "file:../player",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.1.0"
  }
}
